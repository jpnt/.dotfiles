#!/usr/bin/env python3

import sys
import json
import urllib.request
import os
from pathlib import Path
import tomllib

def load_config():
    path = Path("~/.config/llm/config.toml").expanduser()
    if path.exists():
        return tomllib.loads(path.read_text())
    return {
        "url": os.getenv("LLM_URL", "http://localhost:8000/v1"),
        "model": os.getenv("LLM_MODEL", "qwen"),
        "api_key": os.getenv("LLM_API_KEY", "dummy"),
    }


def parse_args() -> tuple[str | None, bool, str]:
    model: str | None = None
    stream = False
    rest: list[str] = []

    it = iter(sys.argv[1:])
    for a in it:
        if a == "-m":
            model = next(it, None)
        elif a == "-s":
            stream = True
        else:
            rest.append(a)

    return model, stream, " ".join(rest)


def read_prompt():
    model, stream, args = parse_args()

    stdin = ""
    if not sys.stdin.isatty():
        stdin = sys.stdin.read()

    return model, stream, args, stdin


def call_llm(cfg: dict[str, str], prompt: str, model: str | None, stream: bool):
    req = urllib.request.Request(
        cfg["url"].rstrip("/") + "/chat/completions",
        data=json.dumps({
            "model": model or cfg["model"],
            "messages": [{"role": "user", "content": prompt}],
            "stream": stream
        }).encode(),
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {cfg['api_key']}",
        },
    )

    with urllib.request.urlopen(req, timeout=60) as r:
        if not stream:
            data = json.load(r)
            return data["choices"][0]["message"]["content"]

        # minimal SSE handling
        for line in r:
            line = line.decode().strip()
            if line.startswith("data: "):
                chunk = line[6:]
                if chunk == "[DONE]":
                    break
                try:
                    j = json.loads(chunk)
                except json.JSONDecodeError:
                    continue
                sys.stdout.write(j["choices"][0]["delta"].get("content", ""))
                sys.stdout.flush()
        return ""


def main():
    model, stream, instruction, data = read_prompt()

    cfg = load_config()

    if not instruction and not data:
        return 1

    # enforce role separation
    if data:
        prompt = instruction + "\n\n" + data
    else:
        prompt = instruction

    try:
        out = call_llm(cfg, prompt, model, stream)
        if not stream:
            print(out)
    except Exception as e:
        print(f"error: {e}", file=sys.stderr)
        return 2

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
