[Unit]
Description=River Wayland Compositor
After=dbus.service
Requires=dbus.service

[Service]
Type=simple
ExecStart=/usr/bin/river
Restart=on-failure
RestartSec=1
StartLimitIntervalSec=60
StartLimitBurst=3

ExecStartPost=/usr/bin/systemctl --user import-environment WAYLAND_DISPLAY DISPLAY

StandardOutput=append:/home/%u/.local/state/river.log
StandardError=append:/home/%u/.local/state/river.log

[Install]
WantedBy=graphical-session.target
BindsTo=graphical-session.target
